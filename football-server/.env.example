# Database
DATABASE_URL=sqlite+aiosqlite:///./football_world_cup.db

# Redis (optional, set REDIS_ENABLED=false to disable)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Deepseek AI
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Application
APP_ENV=development
SCRAPER_ENABLED=false

# Scraper (optional, defaults shown)
FIFA_SCHEDULE_URL=https://www.fifa.com/fifaplus/en/tournaments/mens/worldcup/2026/matchschedule
FIFA_MATCH_URL=https://www.fifa.com/fifaplus/en/tournaments/mens/worldcup/2026/matchcenter
SCRAPER_CONCURRENCY=3
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_MAX=3

# Feishu Bot (optional, set FEISHU_ENABLED=false to disable)
FEISHU_ENABLED=false
FEISHU_PUSH_ENABLED=false          # Phase 1: push match events to Feishu group
FEISHU_BOT_ENABLED=false           # Phase 3: interactive bot (requires webhook URL)
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_CHAT_ID=your_group_chat_id  # Target group chat ID for push notifications
FEISHU_VERIFY_TOKEN=               # Webhook event verification (Phase 3 only)
FEISHU_ENCRYPT_KEY=                # Optional, for event payload encryption
